@sock.route('/api/stream')
def websocket_stream(ws):
    """
    WebSocket endpoint for TRUE REAL-TIME bidirectional audio streaming.
    
    This is the PRIMARY endpoint for continuous speech-to-speech interaction.
    
    Protocol:
    CLIENT → SERVER:
        {"type": "start_request"}  - Start response generation (call when user clicks Start)
        {"type": "audio_chunk", "data": "base64_pcm16", "chunk_index": 0}  - Send PCM-16 audio chunk
        {"type": "audio.commit"}  - Signal end of audio input
        {"type": "text_input", "text": "..."}  - Send text input for processing
        {"type": "interrupt"}  - Stop current response generation
    
    SERVER → CLIENT:
        {"type": "audio_chunk", "data": "base64_pcm16", ...}  - Response audio
        {"type": "transcript", "text": "..."}  - Input transcription
        {"type": "response_text", "text": "..."}  - Response text
        {"type": "tool_call"}  - Tool execution
        {"type": "tool_result"}  - Tool result
        {"type": "response_complete"}  - Response finished
        {"type": "error"}  - Error occurred
    
    Key Features:
    - Incremental audio chunk handling (no waiting for full audio)
    - Bidirectional streaming (simultaneous audio in/out)
    - Persistent connection across multiple turn exchanges
    - Automatic speech-to-speech with audio output
    - Tool execution in background without blocking
    """
    try:
        # Create event loop for async operations
        stream_loop = asyncio.new_event_loop()
        asyncio.set_event_loop(stream_loop)
        
        # Initialize state variables for tracking turns and audio
        response_in_progress = False
        current_turn_id = 0
        turn_append_count = 0
        turn_append_total_chars = 0
        turn_start_time = None
        current_response_id = None
        
        async def handle_websocket_stream():
            """Main WebSocket stream handler"""
            nonlocal response_in_progress, current_turn_id, turn_append_count, turn_append_total_chars, turn_start_time, current_response_id
            
            # === INITIALIZE ALL VARIABLES BEFORE TRY BLOCK ===
            client = None
            audio_chunks_queue = None
            chunk_sender_task = None
            audio_receiver_task = None
            
            try:
                # Connect to Azure Realtime API using official SDK
                # Extract base endpoint from ENDPOINT env var
                azure_endpoint = os.getenv("AZURE_OPENAI_ENDPOINT", "")
                if not azure_endpoint:
                    raise ValueError("AZURE_OPENAI_ENDPOINT not configured")
                
                # Clean endpoint: remove query parameters AND /openai/realtime path
                # Azure SDK expects: https://resource-name.openai.azure.com/
                base_endpoint = azure_endpoint.split("?")[0]  # Remove query params
                base_endpoint = base_endpoint.split("/openai")[0]  # Remove /openai/realtime path
                
                # Ensure it ends with a trailing slash
                if not base_endpoint.endswith("/"):
                    base_endpoint += "/"
                
                deployment = os.getenv("AZURE_OPENAI_DEPLOYMENT", "gpt-4o-mini-realtime-preview")
                
                # Create client with cleaned endpoint
                client = RealtimeClient(API_KEY, base_endpoint, deployment)
                await client.connect()
                
                # Create audio queue for streaming chunks
                audio_chunks_queue = asyncio.Queue()
                
                # === BACKGROUND TASK: Send queued audio chunks to Azure in parallel ===
                async def send_chunks_to_azure():
                    """Continuously send audio chunks from queue to Azure as they arrive"""
                    chunk_idx = 0
                    consecutive_timeouts = 0
                    try:
                        while True:
                            try:
                                # Non-blocking: try to get chunk with timeout
                                # Use 5-second timeout: quick fail for text-only mode, plenty of time for audio chunks
                                audio_data = await asyncio.wait_for(audio_chunks_queue.get(), timeout=5.0)
                                consecutive_timeouts = 0  # Reset counter on successful chunk
                                
                                if audio_data == "END_OF_AUDIO":
                                    chunk_idx = 0  # Reset chunk counter for next turn
                                    continue  # Continue listening for next turn's chunks
                                
                                # IMMEDIATELY send chunk to Azure (in parallel)
                                await client.send_audio_chunk(audio_data, chunk_idx)
                                chunk_idx += 1
                                
                            except asyncio.TimeoutError:
                                # Timeout is OK - might be text-only input mode (no audio)
                                consecutive_timeouts += 1
                                # After 3 consecutive timeouts (15 seconds total), likely no audio coming
                                # but still continue in case audio starts later
                                if consecutive_timeouts >= 3:
                                    consecutive_timeouts = 0  # Reset and keep waiting
                                continue  # Don't break - keep waiting for possible audio
                    except Exception as e:
                        pass
                
                # === BACKGROUND TASK: Receive control messages from WebSocket client ===
                async def receive_client_messages():
                    """Receive messages from WebSocket client and queue audio"""
                    nonlocal response_in_progress, current_turn_id, turn_append_count, turn_append_total_chars, turn_start_time, current_response_id
                    
                    try:
                        while True:
                            # Receive message from browser client
                            # NOTE: ws.receive() is synchronous in Flask-Sock
                            # Must run in executor to avoid blocking event loop
                            message_str = await asyncio.get_event_loop().run_in_executor(None, ws.receive)
                            if not message_str:
                                continue
                            
                            try:
                                msg = json.loads(message_str)
                            except json.JSONDecodeError:
                                continue
                            
                            msg_type = msg.get('type')
                            
                            # === Handle different message types ===
                            if msg_type == 'audio_chunk':
                                audio_data = msg.get('data', '')
                                chunk_idx = msg.get('chunk_index', 0)
                                
                                if audio_data:
                                    # === NEW TURN DETECTION: Increment turn_id when starting fresh chunks ===
                                    if turn_append_count == 0:
                                        current_turn_id += 1
                                        turn_start_time = time.time()
                                    
                                    # Queue chunk for sending to Azure (in parallel)
                                    await audio_chunks_queue.put(audio_data)
                                    turn_append_count += 1
                                    turn_append_total_chars += len(audio_data)
                            
                            elif msg_type == 'audio.commit':
                                # Browser signals end of audio input - NOW REQUEST RESPONSE
                                
                                # === GUARD: Prevent empty buffer commit ===
                                if turn_append_count == 0:
                                    turn_append_count = 0
                                    turn_append_total_chars = 0
                                    continue
                                
                                # === MULTI-TURN GUARD: Auto-cancel if response still active ===
                                if response_in_progress:
                                    await client.interrupt_response()
                                    response_in_progress = False
                                
                                # Signal chunk sender to stop
                                await audio_chunks_queue.put("END_OF_AUDIO")
                                
                                # Wait for last chunks to be sent to Azure
                                await asyncio.sleep(0.2)
                                
                                # Commit the buffer
                                # Azure will automatically generate response (no manual request needed)
                                await client.commit_audio_buffer()
                                response_in_progress = True
                                
                                # === RESET TURN COUNTERS FOR NEXT TURN ===
                                turn_append_count = 0
                                turn_append_total_chars = 0
                            
                            elif msg_type == 'interrupt':
                                # Interrupt current response
                                await client.interrupt_response()
                            
                            elif msg_type == 'start_request':
                                # === START REQUEST HANDLER - User clicked Start button or initiated via text ===
                                # Request response immediately to warm up connection
                                if not response_in_progress:
                                    current_turn_id += 1
                                    turn_start_time = time.time()
                                    session_metrics.log(f"🎯 Start request - initiating response generation")
                                    
                                    # Request response from Azure
                                    await client.request_response(["audio", "text"])
                                    response_in_progress = True
                                
                                # Always send confirmation to frontend (even if response already in progress)
                                # This ensures frontend knows backend is ready for text input
                                ws.send(json.dumps({
                                    "type": "request_ready",
                                    "message": "Response generation started, ready for input"
                                }))
                            
                            elif msg_type == 'text_input':
                                # === TEXT INPUT HANDLER ===
                                user_text = msg.get('text', '').strip()
                                
                                if not user_text:
                                    continue
                                
                                # IMPORTANT: Ensure response generation is active
                                # Even if response_in_progress was reset by response.done,
                                # we need to ensure request_response() is called for the text
                                if not response_in_progress:
                                    current_turn_id += 1
                                    turn_start_time = time.time()
                                    session_metrics.log(f"🎯 Auto-starting response for text input (response_in_progress was False)")
                                    await client.request_response(["audio", "text"])
                                    response_in_progress = True
                                
                                # Send text input to Azure SDK
                                await client.send_text_input(user_text)
                                session_metrics.log(f"💬 Text input received: {user_text[:50]}...")
                                # Azure will automatically generate response for this text
                            
                            else:
                                pass
                    
                    except Exception as e:
                        traceback.print_exc()
                    finally:
                        pass
                
                # Start background tasks
                chunk_sender_task = asyncio.create_task(send_chunks_to_azure())
                audio_receiver_task = asyncio.create_task(receive_client_messages())
                
                # === CONCURRENCY VERIFICATION ===
                # Don't print debug info
                pass
                
                # === VERIFY TASKS ARE NOT DONE YET ===
                await asyncio.sleep(0.01)  # Allow tasks to start
                # Check task status
                pass
                
                # === MAIN RESPONSE STREAMING LOOP ===
                event_counter = {}
                audio_chunk_count = 0
                response_count = 0
                first_audio_time = None
                tool_output_pending = False
                current_response_id = None  # Track current response to ignore old events
                
                try:
                    loop_iteration = 0
                    while True:
                        loop_iteration += 1
                        # Receive event from Azure
                        try:
                            msg = await asyncio.wait_for(client.recv_event(), timeout=120.0)
                        except asyncio.TimeoutError:
                            raise
                        except Exception as e:
                            traceback.print_exc()
                            raise
                        
                        # === Parse event ===
                        event_type = msg.get("type")
                        response_id = msg.get("response_id")
                        
                        # === IMPORTANT: Ignore events from old responses when a new response starts ===
                        if response_id and current_response_id and response_id != current_response_id:
                            # This event is from an old response, skip it
                            continue
                        
                        # Track current response
                        if response_id and not current_response_id:
                            current_response_id = response_id
                        
                        event_counter[event_type] = event_counter.get(event_type, 0) + 1
                        
                        # === Handle different event types from Azure ===
                        
                        # Audio response - THIS IS WHAT WE'RE WAITING FOR
                        if event_type == "response.audio.delta":
                            delta = msg.get("delta", "")
                            if delta:
                                if first_audio_time is None:
                                    first_audio_time = time.time()
                                
                                audio_chunk_count += 1
                                
                                # Forward to client immediately (real-time streaming)
                                ws.send(json.dumps({
                                    "type": "audio_chunk",
                                    "response_id": current_response_id,
                                    "data": delta,
                                    "chunk_id": audio_chunk_count,
                                    "timestamp": time.time()
                                }))
                                
                                if audio_chunk_count % 10 == 0:
                                    pass
                                elif audio_chunk_count == 1:
                                    pass
                        
                        # Text response
                        elif event_type == "response.text.delta":
                            text = msg.get("delta", "")
                            if text:
                                ws.send(json.dumps({
                                    "type": "response_text",
                                    "text": text
                                }))
                                session_metrics.output_chunks += 1
                        
                        # Input transcription
                        elif event_type == "input_audio_transcript.delta":
                            transcript = msg.get("delta", "")
                            if transcript:
                                ws.send(json.dumps({
                                    "type": "transcript",
                                    "text": transcript
                                }))
                                session_metrics.input_chunks += 1
                        
                        # Tool execution - MUST BE NON-BLOCKING
                        elif event_type == "response.function_call_arguments.done":
                            fn = msg.get("name")
                            args = json.loads(msg.get("arguments", "{}"))
                            call_id = msg.get("call_id")
                            
                            session_metrics.tools_called.append({"name": fn, "args": args})
                            
                            # Mark that a tool was called
                            tool_output_pending = True
                            
                            # Send tool call notification to client
                            ws.send(json.dumps({
                                "type": "tool_call",
                                "name": fn,
                                "args": args,
                                "call_id": call_id
                            }))
                            
                            # === Execute tool in background WITHOUT blocking receive loop ===
                            async def execute_tool_background(fn, args, call_id):
                                """Execute tool in background - doesn't block receive loop"""
                                try:
                                    result = await client._execute_tool_async_impl(fn, args)
                                    
                                    # Send result back to Azure
                                    await client._send_message({
                                        "type": "conversation.item.create",
                                        "item": {
                                            "type": "function_call_output",
                                            "call_id": call_id,
                                            "output": json.dumps(result)
                                        }
                                    })
                                    
                                    # Notify client
                                    ws.send(json.dumps({
                                        "type": "tool_result",
                                        "call_id": call_id,
                                        "result": result
                                    }))
                                    session_metrics.tool_results.append({"name": fn, "result": result})
                                    
                                except Exception as e:
                                    traceback.print_exc()
                                    ws.send(json.dumps({
                                        "type": "tool_error",
                                        "call_id": call_id,
                                        "error": str(e)
                                    }))
                            
                            # Start background task WITHOUT awaiting
                            asyncio.create_task(execute_tool_background(fn, args, call_id))
                        
                        # Response complete
                        elif event_type == "response.done":
                            response_in_progress = False  # === Mark response as complete ===
                            current_response_id = None  # Reset response tracking
                            response_count += 1
                            elapsed_ms = (time.time() - turn_start_time) * 1000 if turn_start_time else 0
                            
                            # If tool was called, request new response for audio generation
                            if tool_output_pending:
                                tool_output_pending = False
                                await client.request_response(["audio", "text"])
                                continue  # Continue waiting for next Azure event (response audio)
                            
                            # Reset counters for next cycle
                            audio_chunk_count = 0
                            event_counter = {}
                            turn_append_count = 0
                            turn_append_total_chars = 0
                            
                            # Client will send audio chunks when ready for next exchange
                            pass
                        
                        # Error - CRITICAL to debug
                        elif event_type == "error":
                            error_data = msg.get("error", {})
                            error_msg = error_data.get("message") if isinstance(error_data, dict) else str(error_data)
                            
                            # === DIAGNOSTIC: Log error in context of turn ===
                            ws.send(json.dumps({
                                "type": "error",
                                "message": error_msg
                            }))
                        
                        # Other events
                        else:
                            pass
                
                except asyncio.TimeoutError:
                    ws.send(json.dumps({
                        "type": "error",
                        "message": "Response timeout"
                    }))
                
            except Exception as e:
                traceback.print_exc()
                try:
                    ws.send(json.dumps({
                        "type": "error",
                        "message": str(e)
                    }))
                except:
                    pass
            
            finally:
                # Cleanup all background tasks
                if chunk_sender_task:
                    chunk_sender_task.cancel()
                    try:
                        await chunk_sender_task
                    except:
                        pass
                
                if audio_receiver_task:
                    audio_receiver_task.cancel()
                    try:
                        await audio_receiver_task
                    except:
                        pass
                
                if client:
                    await client.close()
                
                session_metrics.print_summary()
        
        # Run the async handler
        stream_loop.run_until_complete(handle_websocket_stream())
        
    except Exception as e:
        pass
    
    finally:
        try:
            stream_loop.close()
        except:
            pass



