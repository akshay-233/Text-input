# ==============================
class BaseRealtimeClient:
    """
    Persistent client for real-time bidirectional streaming using official Azure SDK.
    
    Wraps the Azure OpenAI SDK's RealtimeConnection (which is synchronous) 
    for use in an async/Flask environment via executor threads.
    
    The SDK handles:
    - WebSocket connection management (no manual WSS needed)
    - Event serialization/deserialization
    - Full session lifecycle management
    """
    
    def __init__(self, api_key: str, azure_endpoint: str, deployment: str):
        """
        Initialize the Realtime client.
        
        Args:
            api_key: Azure OpenAI API key
            azure_endpoint: Azure OpenAI endpoint (base URL without /realtime)
            deployment: Azure deployment name (e.g., gpt-4o-realtime-preview)
        """
        self.api_key = api_key
        self.azure_endpoint = azure_endpoint
        self.deployment = deployment
        self.sdk_client = None
        self.realtime_conn = None  # SDK's RealtimeConnection (sync)
        self.latency = LatencyTracker()
        self.conversation_id = None
        self.input_audio_buffer = deque()
        self.is_sending_audio = False
    
    async def connect(self) -> None:
        """Establish Azure Realtime connection using official SDK"""
        
        try:
            # Initialize Azure OpenAI SDK client with base endpoint
            # The SDK handles all WebSocket and authentication internally
            self.sdk_client = AzureOpenAI(
                api_key=self.api_key,
                api_version="2024-10-01-preview",
                azure_endpoint=self.azure_endpoint
            )
            
            # Create realtime connection using SDK
            # SDK's connect() is synchronous, run it in executor to avoid blocking
            def establish_connection():
                """Establish connection in executor thread (SDK is synchronous)"""
                try:
                    # SDK's connect() handles:
                    # - WebSocket negotiation
                    # - Authentication headers
                    # - Session creation
                    # Returns a context manager -> we enter it to get the actual connection
                    connection_manager = self.sdk_client.beta.realtime.connect(model=self.deployment)
                    
                    # Explicitly enter the context manager to get the active connection
                    realtime_conn = connection_manager.__enter__()
                    return realtime_conn
                except Exception as e:
                    logger.error(f"SDK connection failed: {e}")
                    raise
            
            # Run sync SDK method in executor thread
            self.realtime_conn = await asyncio.get_event_loop().run_in_executor(
                None, 
                establish_connection
            )
            
            # Configure session after connection
            await self._configure_session()
            
        except Exception as e:
            logger.error(f"Failed to connect: {e}")
            raise
    
    async def _send_message(self, message: dict) -> None:
        """Send a message via SDK connection in executor thread"""
        try:
            def send_sync():
                """Send message - SDK method is synchronous"""
                self.realtime_conn.send(message)
            
            await asyncio.get_event_loop().run_in_executor(None, send_sync)
        except Exception as e:
            logger.error(f"Error sending message to Azure: {e}")
            raise
    
    async def _configure_session(self) -> None:
        """Configure realtime session with modalities, tools, and instructions"""
        try:
            session_config = {
                "type": "session.update",
                "session": {
                    "modalities": ["text", "audio"],
                    "input_audio_format": "pcm16",
                    "output_audio_format": "pcm16",
                    "input_audio_transcription": {
                        "model": "whisper-1"
                    },
                    "instructions": (
                        "You are a helpful assistant. "
                        "Answer ONLY the most recent user question. "
                        "If a new question arrives, treat it as a new conversational turn with fresh context. "
                        "Do not repeat or reference previous answers unless explicitly asked. "
                        "Use available tools to help answer user questions. "
                        "After receiving tool result, respond briefly and speak the answer."
                    ),
                    "tool_choice": "auto",
                    "tools": get_tools_schema(),  # Dynamic tool registry
                    "voice": "echo",
                    "temperature": 0.7,
                    "max_response_output_tokens": 4096
                }
            }
            
            await self._send_message(session_config)
            session_metrics.log("🔧 Session configured with tools")
        except Exception as e:
            logger.error(f"Failed to configure session: {e}")
            raise
    
    async def send_audio_chunk(self, audio_base64: str, chunk_index: int = 0) -> None:
        """Send audio chunk to Azure via SDK"""
        message = {
            "type": "input_audio_buffer.append",
            "audio": audio_base64
        }
        
        await self._send_message(message)
    
    async def commit_audio_buffer(self) -> None:
        """Commit audio buffer - signals end of audio input"""
        message = {
            "type": "input_audio_buffer.commit"
        }
        
        await self._send_message(message)
    
    async def send_text_input(self, text: str) -> None:
        """Send text input to Azure for processing"""
        message = {
            "type": "conversation.item.create",
            "item": {
                "type": "message",
                "role": "user",
                "content": [
                    {
                        "type": "input_text",
                        "text": text
                    }
                ]
            }
        }
        
        await self._send_message(message)
    
    async def request_response(self, modalities: list = None) -> None:
        """Request response generation from Azure"""
        message = {
            "type": "response.create"
        }
        
        await self._send_message(message)
    
    async def interrupt_response(self) -> None:
        """Cancel current response generation"""
        message = {
            "type": "response.cancel"
        }
        await self._send_message(message)
    
    async def recv_event(self) -> dict:
        """
        Receive next event from Azure SDK.
        
        SDK returns RealtimeServerEvent objects (Pydantic v2 models).
        This method converts them to JSON-compatible dicts for frontend compatibility.
        """
        def recv_sync():
            """Receive event - SDK method is synchronous"""
            event = self.realtime_conn.recv()
            
            # Convert SDK event object to dict using Pydantic v2 model_dump
            try:
                if hasattr(event, 'model_dump'):
                    # Pydantic v2 - proper way to serialize models
                    return event.model_dump(by_alias=True, exclude_none=False)
                elif hasattr(event, 'dict'):
                    # Fallback for Pydantic v1
                    return event.dict()
                else:
                    # Last resort - JSON serialization with str fallback
                    return json.loads(json.dumps(event, default=str))
            except Exception as e:
                logger.error(f"Error converting SDK event to dict: {e}. Event type: {type(event)}")
                # Return error event
                return {"type": "error", "error": str(e)}
        
        # Run sync receive in executor to avoid blocking event loop
        return await asyncio.get_event_loop().run_in_executor(None, recv_sync)
    
    async def close(self) -> None:
        """Close connection and cleanup"""
        def close_sync():
            """Close connection - SDK method is synchronous"""
            if self.realtime_conn:
                try:
                    self.realtime_conn.close()
                except Exception as e:
                    logger.warning(f"Error closing connection: {e}")
        
        try:
            await asyncio.get_event_loop().run_in_executor(None, close_sync)
        except Exception as e:
            logger.error(f"Error in close: {e}")

