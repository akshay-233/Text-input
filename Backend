async def get_weather_async(location: str):
    """Get weather for a location"""
    try:
        async with httpx.AsyncClient(timeout=10) as client:
            geo_response = await client.get(
                "https://geocoding-api.open-meteo.com/v1/search",
                params={"name": location, "count": 1}
            )
            geo = geo_response.json()
            
            if "results" not in geo or not geo["results"]:
                return {"ok": False, "error": f"Location not found: {location}"}
            
            lat = geo["results"][0]["latitude"]
            lon = geo["results"][0]["longitude"]
            resolved = geo["results"][0]["name"]
            country = geo["results"][0].get("country", "")
            
            weather_response = await client.get(
                "https://api.open-meteo.com/v1/forecast",
                params={"latitude": lat, "longitude": lon, "current_weather": True}
            )
            weather = weather_response.json()
            cw = weather.get("current_weather")
            
            return {
                "ok": True,
                "location": f"{resolved}, {country}",
                "latitude": lat,
                "longitude": lon,
                "current_weather": cw
            }
    except Exception as e:
        return {"ok": False, "error": f"Weather API error: {str(e)}"}

async def calculate_async(expression: str):
    """Calculator tool"""
    try:
        loop = asyncio.get_event_loop()
        result = await loop.run_in_executor(None, lambda: eval(expression))
        return {"ok": True, "expression": expression, "result": result}
    except Exception as e:
        return {"ok": False, "error": str(e)}

TOOLS_REGISTRY = {
    "get_weather": {
        "function": get_weather_async,
        "description": "Get current weather for a city",
        "parameters": {
            "type": "object",
            "properties": {
                "location": {"type": "string"}
            },
            "required": ["location"]
        }
    },
    "calculate": {
        "function": calculate_async,
        "description": "Perform mathematical calculations",
        "parameters": {
            "type": "object",
            "properties": {
                "expression": {"type": "string"}
            },
            "required": ["expression"]
        }
    }
}

def get_tools_schema():
    """Get tool definitions for LLM"""
    return [
        {
            "type": "function",
            "name": name,
            "description": config["description"],
            "parameters": config["parameters"]
        }
        for name, config in TOOLS_REGISTRY.items()
    ]

async def execute_tool_async(tool_name: str, args: dict):
    """Execute a tool asynchronously"""
    if tool_name not in TOOLS_REGISTRY:
        return {"ok": False, "error": f"Tool '{tool_name}' not found"}
    
    tool_func = TOOLS_REGISTRY[tool_name]["function"]
    try:
        return await tool_func(**args)
    except Exception as e:
        return {"ok": False, "error": str(e)}

