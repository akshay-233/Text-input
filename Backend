class SessionMetrics:
    """Track and log only essential session metrics"""
    def __init__(self):
        self.session_id = int(time.time())
        self.start_time = time.time()
        self.input_chunks = 0
        self.output_chunks = 0
        self.tools_called = []
        self.ui_messages_sent = 0
        self.tool_results = []
    
    def log(self, msg):
        """Log a message with timestamp"""
        elapsed = time.time() - self.start_time
        log_msg = f"[{elapsed:.2f}s] {msg}"
        logger.info(log_msg)
    
    def print_summary(self):
        """Print final session summary"""
        total_time = time.time() - self.start_time
        summary = f"""
{'='*70}
SESSION SUMMARY
{'='*70}
📊 Input audio chunks:     {self.input_chunks}
📊 Output audio chunks:    {self.output_chunks}
📊 UI messages sent:       {self.ui_messages_sent}
🔧 Tools called:          {len(self.tools_called)}
⏱️  Total execution time:   {total_time:.2f}s
{'='*70}
"""
        if self.tools_called:
            summary += "Tools executed:\n"
            for i, tool in enumerate(self.tools_called, 1):
                summary += f"  {i}. {tool['name']}({tool['args']})\n"
        summary += f"\n🔵 Session ID: {self.session_id}\n"
        logger.info(summary)

session_metrics = SessionMetrics()

