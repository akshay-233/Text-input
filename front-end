        // ===== WEBSOCKET CONNECTION =====
        async function connectWebSocket() {
            return new Promise((resolve, reject) => {
                // Check if we can reuse existing
                if (ws && ws.readyState === WebSocket.OPEN) {
                    resolve();
                    return;
                }
               
                ws = new WebSocket(WS_URL);

                ws.onopen = () => {
                    setStatus('Connected', 'ready');
                    resolve();
                };
               
                ws.onerror = (error) => {
                    console.error(`WebSocket error:`, error);
                    reject(error);
                };

                ws.onclose = () => {
                    setStatus('Disconnected', 'error');
                };

                ws.onmessage = (event) => {
                    try {
                        const msg = JSON.parse(event.data);
                        const msgType = msg.type;
                       
                        if (msgType === 'response_start') {
                            if (globalAudioBuffer === null) {
                                globalAudioBuffer = new StreamingAudioPlayer();
                                audioChunkCount = 0;
                            }
                        }
                       
                        else if (msgType === 'audio_chunk') {
                            const responseId = msg.response_id || 'default';  // Get response_id from chunk
                           
                            // NEW RESPONSE DETECTED: Create fresh buffer for this response
                            if (currentResponseSession !== responseId) {
                                // Clear old buffer when new response starts
                                if (globalAudioBuffer) {
                                    try {
                                        globalAudioBuffer.close();
                                    } catch (e) {
                                        console.warn('Error closing old buffer:', e.message);
                                    }
                                }
                                // Create fresh buffer for NEW response
                                globalAudioBuffer = new StreamingAudioPlayer();
                                audioChunkCount = 0;
                                currentResponseSession = responseId;  // Track this response
                            }
                           
                            audioChunkCount++;
                            const base64Data = msg.data;
                           
                            try {
                                // Decode base64 PCM-16 immediately
                                const binaryString = atob(base64Data);
                                const bytes = new Uint8Array(binaryString.length);
                                for (let i = 0; i < binaryString.length; i++) {
                                    bytes[i] = binaryString.charCodeAt(i);
                                }
                               
                                // APPEND TO GLOBAL PLAYER
                                globalAudioBuffer.addChunk(bytes.buffer)
                                    .catch(err => {
                                        console.error(`Error appending chunk to buffer:`, err);
                                        showError(`Audio playback error: ${err.message}`);
                                    });
                            } catch (decodeError) {
                                console.error(`Base64 decode error:`, decodeError);
                                showError(`Audio decode error: ${decodeError.message}`);
                            }
                        }
                       
                        else if (msgType === 'response_text') {
                            const text = msg.text || '';
                            const outputSection = document.getElementById('output-section');
                            if (!outputSection.classList.contains('visible')) {
                                outputSection.classList.add('visible');
                            }
                            let textContainer = document.getElementById('response-text-content');
                            if (!textContainer) {
                                outputSection.innerHTML = '<h3>✨ Response</h3><div id="response-text-content"></div>';
                                textContainer = document.getElementById('response-text-content');
                            }
                            textContainer.textContent += text;
                        }
                       
                        else if (msgType === 'transcript') {
                            const transcript = msg.text || '';
                            let transcriptContainer = document.getElementById('input-transcript-content');
                            if (!transcriptContainer) {
                                const outputSection = document.getElementById('output-section');
                                const transcriptBox = document.createElement('div');
                                transcriptBox.className = 'transcription-box';
                                transcriptBox.innerHTML = `
                                    <div class="transcription-label">Your Voice</div>
                                    <div class="transcription-text" id="input-transcript-content">${transcript}</div>
                                `;
                                outputSection.appendChild(transcriptBox);
                                transcriptContainer = document.getElementById('input-transcript-content');
                            } else {
                                transcriptContainer.textContent += transcript;
                            }
                        }
                       
                        else if (msgType === 'response_complete') {
                            // Signal buffer that no more chunks coming for this response
                            if (globalAudioBuffer && typeof globalAudioBuffer.finish === 'function') {
                                globalAudioBuffer.finish();
                            }
                            setStatus('Ready', 'ready');
                        }
                       
                        else if (msgType === 'event' && msg.event) {
                            setStatus('Processing...', 'processing');
                        }
                       
                        else if (msgType === 'error') {
                            console.error('Backend error:', msg.message);
                            showError(`Server error: ${msg.message}`);
                            setStatus('Error', 'error');
                        }
                       
                        else if (msgType === 'request_ready') {
                            // Backend confirmation that request_response() was called
                            // This is used for synchronization in text input flow
                            if (window.onRequestReady) {
                                window.onRequestReady();
                            }
                        }
                    } catch (err) {
                        console.error('WebSocket message parsing error:', err);
                    }
                };
            });
        }

        // ===== VOICE RECORDING =====
        async function startRecording() {
            try {
                currentTurnId++;
                turnChunksSent = 0;
               
                // SAFE CLEANUP OF OLD AUDIO RESOURCES
                if (audioContext && audioContext.state === 'closed') {
                    audioContext = null;
                }
                if (audioProcessor) {
                    try {
                        audioProcessor.disconnect();
                    } catch (e) {
                        console.warn('Error disconnecting old processor:', e.message);
                    }
                    audioProcessor = null;
                }
               
                // CONNECT WEBSOCKET
                await connectWebSocket();
               
                // SEND START REQUEST TO WARM UP CONNECTION AND BEGIN RESPONSE GENERATION
                try {
                    ws.send(JSON.stringify({ type: 'start_request' }));
                } catch (err) {
                    console.warn('Could not send start_request:', err);
                }
               
                // REQUEST FRESH MICROPHONE STREAM
                rawAudioStream = await navigator.mediaDevices.getUserMedia({
                    audio: {
                        echoCancellation: true,
                        noiseSuppression: true,
                        autoGainControl: true,
                        sampleRate: { ideal: SAMPLE_RATE }
                    }
                });
               
                // SETUP WEB AUDIO PIPELINE
                audioProcessor = await setupAudioProcessor(rawAudioStream);
                if (!audioProcessor) {
                    throw new Error('Failed to create audio processor');
                }
               
                // ENABLE RECORDING FLAG
                isRecording = true;
                audioFrameCounter = 0;
               
                // RESET STATE FOR THIS TURN
                pcm16Chunks = [];
                silenceStartTime = null;
                silenceDetected = false;

                // UPDATE UI
                document.getElementById('start-btn').disabled = true;
                document.getElementById('stop-btn').disabled = false;
                document.getElementById('recording-indicator').style.display = 'flex';
                document.getElementById('voice-context').disabled = true;

                recordingStartTime = Date.now();
                recordingIntervalId = setInterval(() => {
                    const elapsed = (Date.now() - recordingStartTime) / 1000;
                    document.getElementById('recording-time').textContent = formatDuration(elapsed);
                }, 100);

                setStatus('Recording...', 'processing');
                document.getElementById('recorder-status-text').textContent = 'Recording in progress... (Turn ' + currentTurnId + ')';

            } catch (error) {
                console.error('startRecording error:', error);
                showError('Error: ' + error.message);
                setStatus('Error', 'error');
               
                // Cleanup on error
                try {
                    if (rawAudioStream) {
                        rawAudioStream.getTracks().forEach(t => t.stop());
                        rawAudioStream = null;
                    }
                } catch (e) { }
            }
        }

        function stopRecording() {
            // DISABLE RECORDING IMMEDIATELY
            isRecording = false;
           
            // NOTE: Do NOT close globalAudioBuffer - it's for output playback!
            // Output audio should continue playing after microphone is stopped.
            // Only close the recording-related audio resources.
           
            // STOP RECORDING TIMER
            clearInterval(recordingIntervalId);
           
            // DISCONNECT AUDIO PIPELINE (INPUT ONLY)
            try {
                if (audioProcessor) {
                    audioProcessor.disconnect();
                }
                audioProcessor = null;
            } catch (e) {
                console.warn(`Error disconnecting processor:`, e.message);
            }
           
            // STOP MEDIASTREAM TRACKS (INPUT MICROPHONE)
            if (rawAudioStream) {
                rawAudioStream.getTracks().forEach((track) => {
                    track.stop();
                });
                rawAudioStream = null;
            }
           
            // CLOSE AUDIOCONTEXT (Recording context only)
            if (audioContext && audioContext.state !== 'closed') {
                try {
                    audioContext.close();
                } catch (e) {
                    console.warn(`Warning closing context:`, e.message);
                }
            }
            audioContext = null;
           
            // UPDATE UI
            document.getElementById('start-btn').disabled = false;
            document.getElementById('stop-btn').disabled = true;
            document.getElementById('recording-indicator').style.display = 'none';
            document.getElementById('voice-context').disabled = false;

            // VALIDATE AND SEND COMMIT
            setTimeout(() => {
                // CRITICAL VERIFICATION: No chunks recorded?
                if (turnChunksSent === 0) {
                    console.error(`No audio chunks were sent!`);
                    showError('No audio detected! Please check microphone and try again.');
                    setStatus('Error', 'error');
                    pcm16Chunks = [];
                    return;
                }
               
                if (turnChunksSent < 10) {
                    console.warn(`Very few chunks sent (${turnChunksSent}). Audio may be too short.`);
                }
               
                document.getElementById('recorder-status-text').innerHTML = `
                    <strong>✓ Recording complete (Turn ${currentTurnId})</strong><br>
                    <small>${turnChunksSent} chunks sent</small><br>
                    Waiting for response...
                `;

                setStatus('Processing...', 'processing');
               
                // SEND AUDIO.COMMIT VIA WEBSOCKET
                if (ws && ws.readyState === WebSocket.OPEN) {
                    ws.send(JSON.stringify({
                        type: "audio.commit"
                    }));
                } else {
                    console.error(`WebSocket NOT OPEN. Cannot send commit.`);
                    showError('Connection lost. Please reconnect.');
                    setStatus('Error', 'error');
                }
               
                pcm16Chunks = [];
            }, 100);
        }

        function visualizeAudio() {
            const canvas = document.getElementById('waveform-canvas');
            const ctx = canvas.getContext('2d');
            const width = canvas.width;
            const height = canvas.height;

            ctx.fillStyle = '#f0f0f0';
            ctx.fillRect(0, 0, width, height);

            ctx.strokeStyle = '#667eea';
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(0, height / 2);

            for (let i = 0; i < audioChunks.length; i++) {
                const x = (i / audioChunks.length) * width;
                const y = height / 2 + Math.random() * (height / 2) - height / 4;
                ctx.lineTo(x, y);
            }

            ctx.stroke();
        }



        // ===== STREAMING AUDIO PLAYER =====
        class StreamingAudioPlayer {
            constructor() {
                // Create SEPARATE AudioContext for playback
                try {
                    this.audioContext = new (window.AudioContext || window.webkitAudioContext)({
                        sampleRate: SAMPLE_RATE
                    });
                } catch (e) {
                    console.error('Failed to create playback AudioContext:', e);
                    throw e;
                }
               
                this.sampleRate = SAMPLE_RATE;
                this.nextScheduleTime = this.audioContext.currentTime;
                this.chunkCount = 0;
                this.totalSamples = 0;
                this.isPlaying = false;
                this.lastChunkTime = null;
            }

            async addChunk(pcm16Buffer) {
                try {
                    // Resume AudioContext if suspended (user interaction required)
                    if (this.audioContext.state === 'suspended') {
                        await this.audioContext.resume();
                    }

                    // Convert PCM-16 (Int16Array) to Float32Array for Web Audio
                    const pcm16View = new Int16Array(pcm16Buffer);
                    const float32Buffer = new Float32Array(pcm16View.length);
                   
                    for (let i = 0; i < pcm16View.length; i++) {
                        // Normalize PCM-16 to float32 range [-1.0, 1.0]
                        float32Buffer[i] = pcm16View[i] / 32768.0;
                    }
                   
                    this.chunkCount++;
                    const sampleCount = pcm16View.length;
                    this.totalSamples += sampleCount;

                    // Create AudioBuffer for this chunk
                    const audioBuffer = this.audioContext.createBuffer(
                        1,  // mono
                        sampleCount,
                        this.sampleRate
                    );
                   
                    const channelData = audioBuffer.getChannelData(0);
                    channelData.set(float32Buffer);

                    // Create bufferSource and schedule for immediate playback
                    const bufferSource = this.audioContext.createBufferSource();
                    bufferSource.buffer = audioBuffer;
                    bufferSource.connect(this.audioContext.destination);
                   
                    // Schedule at the next available playback time
                    const scheduleTime = this.nextScheduleTime;
                    bufferSource.start(scheduleTime);

                    // Update next schedule time for next chunk
                    const chunkDuration = sampleCount / this.sampleRate;
                    this.nextScheduleTime += chunkDuration;
                   
                    if (!this.isPlaying) {
                        this.isPlaying = true;
                        this.lastChunkTime = Date.now();
                    }
                    this.lastChunkTime = Date.now();

              } catch (error) {
                    console.error(`StreamingAudioPlayer.addChunk error:`, error);
                    throw error;
                }
            }

            getDuration() {
                if (this.nextScheduleTime && this.audioContext) {
                    return Math.max(0, this.nextScheduleTime - this.audioContext.currentTime);
                }
                return 0;
            }

            getStats() {
                return {
                    chunkCount: this.chunkCount,
                    totalSamples: this.totalSamples,
                    totalDuration: (this.totalSamples / this.sampleRate).toFixed(2),
                    isPlaying: this.isPlaying,
                    audioContextState: this.audioContext?.state
                };
            }

            close() {
                if (this.audioContext && this.audioContext.state !== 'closed') {
                    this.audioContext.close();
                }
            }
        }

        // ===== PROCESSING FUNCTIONS =====
        async function processAudioStream(audioFile, context, buttonId) {
            setStatus('Streaming audio...', 'processing');
            document.getElementById(buttonId).disabled = true;

            const player = new StreamingAudioPlayer();
            const startTime = performance.now();

            try {
                if (!audioFile) {
                    throw new Error('No audio file selected');
                }

                if (audioFile.size === 0) {
                    throw new Error('Audio file is empty');
                }

                // Prepare FormData with PCM-16 chunks
                const formData = new FormData();
               
                // Add raw PCM-16 audio data
                formData.append('audio_data', audioFile, 'audio.pcm16');
                formData.append('sample_rate', SAMPLE_RATE.toString());
                formData.append('channels', '1');  // Mono
                formData.append('bit_depth', '16');  // PCM-16
               
                if (context) {
                    formData.append('text_input', context);
                }

                const response = await fetch(`${API_BASE}/process-audio-stream`, {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                // Read streaming response
                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                let buffer = '';
                let responseText = '';
                let inputTranscript = '';
                let toolsCalled = [];
                let latencyMetrics = {};

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;

                    buffer += decoder.decode(value, { stream: true });
                    const lines = buffer.split('\n');
                    buffer = lines.pop() || '';

                    for (const line of lines) {
                        if (!line.trim()) continue;

                        try {
                            const event = JSON.parse(line);

                            // Audio chunks
                            if (event.type === 'audio_chunk') {
                                // Decode base64 to PCM16
                                const binaryString = atob(event.data);
                                const bytes = new Uint8Array(binaryString.length);
                                for (let i = 0; i < binaryString.length; i++) {
                                    bytes[i] = binaryString.charCodeAt(i);
                                }

                                player.addChunk(bytes.buffer);
                            }

                            // Response metadata
                            else if (event.type === 'response_complete') {
                                responseText = event.response_text;
                                inputTranscript = event.input_transcript;
                                toolsCalled = event.tools_called || [];
                                latencyMetrics = event.latency || {};
                            }

                            // Error
                            else if (event.type === 'error') {
                                throw new Error(event.message);
                            }
                        } catch (parseError) {
                            console.warn('Parse error:', parseError, 'Line:', line);
                        }
                    }
                }

                // Display results
                const duration = player.getDuration();
               
                displayStreamingOutput({
                    duration: duration,
                    responseText: responseText,
                    inputTranscript: inputTranscript,
                    toolsCalled: toolsCalled,
                    latency: latencyMetrics,
                    totalChunks: player.chunkCount,
                }, player);

                showSuccess('Stream received! Playing audio...');
                await player.playback();

            } catch (error) {
                console.error('Stream error:', error);
                showError('Error: ' + error.message);
                setStatus('Error', 'error');
            } finally {
                document.getElementById(buttonId).disabled = false;
            }
        }

        function displayStreamingOutput(data, player) {
            const outputSection = document.getElementById('output-section');
            outputSection.classList.add('visible');

            // Clear previous output
            outputSection.innerHTML = `<h3>✨ Response</h3>`;

            // Text response
            if (data.responseText) {
                outputSection.innerHTML += `
                    <div class="transcription-box">
                        <div class="transcription-label">AI Response</div>
                        <div class="transcription-text">${escapeHtml(data.responseText)}</div>
                    </div>
                `;
            }

            // Input transcription
            if (data.inputTranscript) {
                outputSection.innerHTML += `
                    <div class="transcription-box" style="border-left-color: #ff9800;">
                        <div class="transcription-label">Your Audio Transcription</div>
                        <div class="transcription-text">${escapeHtml(data.inputTranscript)}</div>
                    </div>
                `;
            }

            // Tools used
            if (data.toolsCalled && data.toolsCalled.length > 0) {
                const toolsHtml = data.toolsCalled.map(t =>
                    `${t.name}(${JSON.stringify(t.args)})`
                ).join(', ');
                outputSection.innerHTML += `
                    <div class="transcription-box" style="border-left-color: #4caf50;">
                        <div class="transcription-label">🔧 Tools Used</div>
                        <div class="transcription-text">${escapeHtml(toolsHtml)}</div>
                    </div>
                `;
            }

            // Metadata with latency
            outputSection.innerHTML += `
                <div class="metadata-box">
                    <div class="metadata-row">
                        <span class="metadata-label">Audio Duration:</span>
                        <span class="metadata-value">${formatDuration(data.duration || 0)}</span>
                    </div>
                    ${data.latency?.first_audio_chunk ? `
                    <div class="metadata-row">
                        <span class="metadata-label">TTFC (Time-to-First-Chunk):</span>
                        <span class="metadata-value">${(data.latency.first_audio_chunk * 1000).toFixed(0)}ms</span>
                    </div>` : ''}
                    ${data.latency?.total_time ? `
                    <div class="metadata-row">
                        <span class="metadata-label">Total Processing Time:</span>
                        <span class="metadata-value">${(data.latency.total_time).toFixed(3)}s</span>
                    </div>` : ''}
                    <div class="metadata-row">
                        <span class="metadata-label">Total Chunks Streamed:</span>
                        <span class="metadata-value">${data.totalChunks}</span>
                    </div>
                    <div class="metadata-row">
                        <span class="metadata-label">Total Audio Data:</span>
                        <span class="metadata-value">${(data.totalBytes / 1024).toFixed(2)}KB</span>
                    </div>
                    <div class="metadata-row">
                        <span class="metadata-label">Avg Chunk Size:</span>
                        <span class="metadata-value">${(data.totalBytes / data.totalChunks).toFixed(0)}B</span>
                    </div>
                </div>
            `;

            // Event log for debugging
            if (data.eventCounter && Object.keys(data.eventCounter).length > 0) {
                const eventList = Object.entries(data.eventCounter)
                    .map(([type, count]) => `<div style="padding: 5px; font-family: monospace; font-size: 12px;">📨 [${count}] ${type}</div>`)
                    .join('');
               
                outputSection.innerHTML += `
                    <div class="metadata-box" style="background-color: #f9f9f9; border: 1px solid #ddd;">
                        <div style="font-weight: bold; margin-bottom: 10px;">📊 Event Stream Log</div>
                        <div style="max-height: 200px; overflow-y: auto; font-size: 12px; font-family: monospace;">
                            ${eventList}
                        </div>
                        <div style="margin-top: 10px; padding-top: 10px; border-top: 1px solid #ddd; font-size: 12px; color: #666;">
                            ${data.eventCounter['response.audio.delta'] > 0
                                ? `✅ Audio streaming working (${data.eventCounter['response.audio.delta']} chunks)`
                                : `❌ No audio chunks received - check backend configuration`}
                        </div>
                    </div>
                `;
            }

            // Scroll to output
            outputSection.scrollIntoView({ behavior: 'smooth' });
            setStatus('Ready', 'ready');
        }

        function escapeHtml(text) {
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.replace(/[&<>"']/g, char => map[char]);
        }

        /**
         * Request response generation while still recording.
         * This enables true full-duplex: response audio plays WHILE user continues speaking.
         */
        function requestResponse() {
            // VALIDATION
            if (!isRecording) {
                showError('Start recording first before requesting response');
                return;
            }

            if (ws && ws.readyState !== WebSocket.OPEN) {
                showError('WebSocket connection lost. Please reconnect.');
                return;
            }

            if (turnChunksSent === 0) {
                showError('No audio detected yet. Please speak first.');
                return;
            }

            // SEND RESPONSE.CREATE MESSAGE
            ws.send(JSON.stringify({
                type: "response_create"
            }));

            // UPDATE UI
            document.getElementById('recorder-status-text').innerHTML = `
                <strong>🎯 Response requested</strong><br>
                <small>Recording continues... you can keep speaking</small><br>
                Audio will play while you speak
            `;

            setStatus('Processing...', 'processing');
        }

        // ===== TEXT INPUT SUPPORT =====
        /**
         * Send text input via WebSocket to backend
         * Should trigger same audio response as voice input
         */
        async function sendTextInput() {
            const textInput = document.getElementById('text-input');
            const text = textInput.value.trim();

            if (!text) {
                showError('Please enter text to send');
                return;
            }

            // CONNECT WEBSOCKET IF NOT ALREADY CONNECTED
            try {
                if (!ws || ws.readyState !== WebSocket.OPEN) {
                    await connectWebSocket();
                }
            } catch (err) {
                showError('Failed to connect WebSocket');
                return;
            }
           
            // === INITIALIZE AUDIO OUTPUT INFRASTRUCTURE ===
            // Text input must also support audio output, just like voice input
            // Pre-initialize buffer to ensure it's ready for response audio
            if (globalAudioBuffer === null) {
                globalAudioBuffer = new StreamingAudioPlayer();
                audioChunkCount = 0;
                currentResponseSession = null;
            }
           
            // SEND START REQUEST FIRST
            // This ensures request_response() is called before text is sent
            try {
                // Set up callback to wait for backend confirmation
                const requestReadyPromise = new Promise((resolve) => {
                    window.onRequestReady = () => {
                        window.onRequestReady = null;  // Clear callback
                        resolve();
                    };
                    // Fallback timeout if confirmation doesn't arrive (should be instant)
                    setTimeout(() => {
                        if (window.onRequestReady) {  // Still waiting
                            window.onRequestReady = null;
                            resolve();  // Continue anyway
                        }
                    }, 2000);
                });
               
                ws.send(JSON.stringify({ type: 'start_request' }));
               
                // Wait for backend to confirm request_response() was called
                await requestReadyPromise;
            } catch (err) {
                console.warn('Issue with start_request:', err);
                showError('Failed to start response generation');
                return;
            }
           
            // Send text input message to backend
            const message = {
                type: 'text_input',
                text: text
            };
           
            try {
                ws.send(JSON.stringify(message));
            } catch (err) {
                console.error(`Failed to send text input:`, err);
                showError(`Failed to send text: ${err.message}`);
                return;
            }

            // Clear input field
            textInput.value = '';
            showSuccess('✅ Text sent!');
        }

        // ===== KEYBOARD SUPPORT FOR TEXT INPUT =====
        // Handle ENTER key in text input field (submit on Enter, allow Shift+Enter for new line)
        document.addEventListener('DOMContentLoaded', function() {
            const textInput = document.getElementById('text-input');
            if (textInput) {
                textInput.addEventListener('keydown', function(event) {
                    // Send on ENTER key (without Shift)
                    if (event.key === 'Enter' && !event.shiftKey) {
                        event.preventDefault();
                        sendTextInput();
                    }
                });
            }
        });

        // ===== KEYBOARD SHORTCUTS =====
        document.addEventListener('keypress', function(e) {
            // Enter key: Request response while recording
            if (e.key === 'Enter' && isRecording) {
                requestResponse();
            }
        });

        // ===== INITIALIZATION =====
        window.addEventListener('load', () => {
            setStatus('Ready', 'ready');
        });

        // Initialize waveform canvas
        const canvas = document.getElementById('waveform-canvas');
        canvas.width = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#f0f0f0';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
    </script>
</body>
</html>
