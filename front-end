        // ===== PCM-16 CONVERSION UTILITIES =====
        /**
         * Convert float32 audio samples to PCM16 (signed 16-bit integers)
         * @param {Float32Array} float32Samples - Float32 audio samples (-1.0 to 1.0)
         * @returns {ArrayBuffer} PCM16 data as Uint8Array buffer
         */
        function floatTo16BitPCM(float32Samples) {
            const pcm16 = new Int16Array(float32Samples.length);
            for (let i = 0; i < float32Samples.length; i++) {
                // Clamp to [-1, 1] then convert to 16-bit integer
                const value = Math.max(-1, Math.min(1, float32Samples[i]));
                pcm16[i] = value < 0 ? value * 0x8000 : value * 0x7FFF;
            }
            return pcm16.buffer;
        }

        /**
         * Calculate RMS (Root Mean Square) of audio samples
         * @param {Float32Array} samples - Audio samples
         * @returns {number} RMS value
         */
        function calculateRMS(samples) {
            let sum = 0;
            for (let i = 0; i < samples.length; i++) {
                sum += samples[i] * samples[i];
            }
            return Math.sqrt(sum / samples.length);
        }

        /**
         * Handle silence detection - MODIFIED for true full-duplex
         * Now ONLY logs silence, doesn't auto-stop recording.
         * User must manually click "Request Response" button.
         * @param {number} rms - RMS value
         */
        function handleSilenceDetection(rms) {
            if (rms < SILENCE_RMS_THRESHOLD) {
                if (silenceStartTime === null) {
                    silenceStartTime = Date.now();
                }
                const silenceDuration = Date.now() - silenceStartTime;
               
                // Only warn user if silence is prolonged, don't auto-stop
                if (silenceDuration >= 2000 && !silenceDetected) {
                    silenceDetected = true;
                    // Don't stop recording!
                }
            } else {
                // Reset silence detection when sound is detected
                silenceStartTime = null;
                silenceDetected = false;
            }
        }

        /**
         * Create an AudioWorklet processor for real-time audio conversion
         * Falls back to ScriptProcessorNode if AudioWorklet not available
         *
         * IMPORTANT: This function is called AFTER old resources are cleaned up
         * in startRecording(), so we can safely create a fresh pipeline.
         */
        async function setupAudioProcessor(stream) {
           
            // CREATE NEW AUDIOCONTEXT
            if (audioContext && audioContext.state === 'closed') {
                audioContext = null;
            }
           
            try {
                audioContext = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: SAMPLE_RATE });
            } catch (e) {
                console.error(`Failed to create AudioContext:`, e);
                throw e;
            }
           
            // RESUME IF SUSPENDED
            if (audioContext.state === 'suspended') {
                try {
                    await audioContext.resume();
                } catch (e) {
                    console.error(`Could not resume AudioContext:`, e.message);
                }
            }
           
            // CREATE MEDIASTREAMSOURCE
            let source;
            try {
                source = audioContext.createMediaStreamSource(stream);
            } catch (e) {
                console.error(`Failed to create MediaStreamSource:`, e);
                throw e;
            }

            // Fallback: ScriptProcessorNode (deprecated but widely supported)
            const bufferSize = 4096;
            const processor = audioContext.createScriptProcessor(bufferSize, 1, 1);
           
            try {
                source.connect(processor);
            } catch (e) {
                console.error(`Failed to connect source to processor:`, e);
                throw e;
            }
           
            // DUPLEX_MIC_GRAPH_FIX: Route microphone through silent gain to prevent playback suppression
            // The mic capture graph must NOT connect directly to destination
            // Direct connection causes browser to treat mic as monitored audio and suppress playback
            try {
                // Create silent (zero gain) node to absorb processor output without causing mic suppression
                const silentGain = audioContext.createGain();
                silentGain.gain.setValueAtTime(0, audioContext.currentTime);
               
                // Connect processor to silent sink ONLY (microphone monitoring disabled)
                processor.connect(silentGain);
                silentGain.connect(audioContext.destination);
            } catch (e) {
                console.error(`Failed to connect processor chain:`, e);
                throw e;
            }
           
            processor.onaudioprocess = (event) => {
                // EARLY EXIT: If not recording, skip
                if (!isRecording) {
                    return;
                }
               
                audioFrameCounter++;
               
                const float32Data = event.inputBuffer.getChannelData(0);
                const rms = calculateRMS(float32Data);
                const pcm16Buffer = floatTo16BitPCM(float32Data);
                const pcm16Chunk = new Uint8Array(pcm16Buffer);
               
                pcm16Chunks.push(pcm16Chunk);
                handleSilenceDetection(rms);
               
                // SEND CHUNK VIA WEBSOCKET
                if (ws && ws.readyState === WebSocket.OPEN) {
                    const base64PCM = btoa(String.fromCharCode.apply(null, pcm16Chunk));
                    ws.send(JSON.stringify({
                        type: "audio_chunk",
                        data: base64PCM
                    }));
                    turnChunksSent++;
                }
            };
           
            return processor;
        }

